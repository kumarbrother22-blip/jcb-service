<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ business.name }}{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>
    <header class="site-header">
        <div class="topbar">
            <p>{{ business.location }}</p>
            <div class="topbar-actions">
                <a href="{{ business.phone_href }}">{{ business.phone_display }}</a>
                <a href="{{ whatsapp_link }}" target="_blank" rel="noopener">WhatsApp</a>
            </div>
        </div>
        <nav class="navbar">
            <a class="brand" href="{{ url_for('home') }}">
                <span class="brand-mark">JCB</span>
                <span>
                    <strong>{{ business.name }}</strong>
                    <small>{{ business.tagline }}</small>
                </span>
            </a>
            <ul class="nav-links">
                <li><a href="{{ url_for('home') }}">Home</a></li>
                <li><a href="{{ url_for('services') }}">Services</a></li>
                <li><a href="{{ url_for('gallery') }}">Gallery</a></li>
                <li><a href="{{ url_for('about') }}">About</a></li>
                <li><a href="{{ url_for('contact') }}">Contact</a></li>
            </ul>
        </nav>
    </header>

    <main>
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                <section class="flash-stack container">
                    {% for category, message in messages %}
                        <div class="flash flash-{{ category }}">{{ message }}</div>
                    {% endfor %}
                </section>
            {% endif %}
        {% endwith %}
        {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
        <section class="footer-cta container">
            <div>
                <p class="section-kicker">Need JCB support quickly?</p>
                <h2>Talk to us about your next job site.</h2>
                <p>We help with excavation, loading, leveling, trenching, and site preparation across residential, commercial, and industrial work.</p>
            </div>
            <div class="footer-cta-actions">
                <a class="btn-primary" href="{{ business.phone_href }}">Call {{ business.phone_display }}</a>
                <a class="btn-secondary" href="{{ whatsapp_link }}" target="_blank" rel="noopener">Message on WhatsApp</a>
            </div>
        </section>
        <section class="footer-meta container">
            <div>
                <h3>{{ business.name }}</h3>
                <p>{{ business.tagline }}</p>
            </div>
            <div>
                <p><strong>Phone:</strong> <a href="{{ business.phone_href }}">{{ business.phone_display }}</a></p>
                <p><strong>Email:</strong> <a href="mailto:{{ business.email }}">{{ business.email }}</a></p>
            </div>
            <div>
                <p><strong>Coverage:</strong> {{ business.location }}</p>
                <p><strong>Working Hours:</strong> {{ business.hours }}</p>
            </div>
        </section>
    </footer>
</body>
</html>
